from sqlalchemy import text

with engine.connect() as conn:

    result = conn.execute(text("""
        SELECT
            file_name,
            records_loaded,
            status,
            load_timestamp
        FROM etl_file_log
        ORDER BY id DESC
        LIMIT 10
    """))

    for row in result:
